generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlanTier {
  FREE
  PRO
  ENTERPRISE
}

// =========================================================================
// NEXTAUTH MODELS (Untouched as requested)
// =========================================================================

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  
  storeMembers  StoreMember[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// =========================================================================
// SAAS & TENANT MODELS
// =========================================================================

model SubscriptionPlan {
  id          String   @id @default(uuid()) @db.Uuid
  tier        PlanTier @default(FREE)
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("IDR") @db.VarChar(10)
  interval    String   @default("MONTHLY") @db.VarChar(50)
  maxBranches Int      @default(1)
  maxUsers    Int      @default(1)
  features    Json
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  subscriptions StoreSubscription[]

  @@map("subscription_plans")
}

model StoreSubscription {
  id                   String   @id @default(uuid()) @db.Uuid
  storeId              String   @unique @map("store_id") @db.Uuid
  planId               String   @map("plan_id") @db.Uuid
  status               String   @default("TRIAL") @db.VarChar(50)
  xenditCustomerId     String?  @map("xendit_customer_id")
  xenditSubscriptionId String?  @unique @map("xendit_subscription_id")
  currentPeriodStart   DateTime @default(now()) @map("current_period_start") @db.Timestamptz
  currentPeriodEnd     DateTime @map("current_period_end") @db.Timestamptz
  cancelAtPeriodEnd    Boolean  @default(false) @map("cancel_at_period_end")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz

  store Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  plan  SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@map("store_subscriptions")
}

model Store {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  subscription        StoreSubscription?
  members             StoreMember[]
  branches            StoreBranch[]
  warehouses          Warehouse[]
  providers           Provider[]
  products            Product[]
  productProviders    ProductProvider[]
  productTransactions ProductTransaction[]
  customers           Customer[]
  orders              Order[]
  orderLines          OrderLine[]
  payments            Payment[]

  @@map("pos_stores")
}

model StoreMember {
  id        String   @id @default(uuid()) @db.Uuid
  storeId   String   @map("store_id") @db.Uuid
  userId    String   @map("user_id")
  role      String   @default("CASHIER") @db.VarChar(50) // OWNER, MANAGER, CASHIER
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storeId, userId])
  @@index([userId])
  @@map("pos_store_members")
}

// =========================================================================
// RETAIL DOMAIN (Streamlined)
// =========================================================================

model Customer {
  id        String   @id @default(uuid()) @db.Uuid
  storeId   String   @map("store_id") @db.Uuid
  name      String   @db.VarChar(255)
  email     String?  @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  points    Decimal  @default(0) @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  store  Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("pos_customers")
}

model Provider {
  id        String   @id @default(uuid()) @db.Uuid
  storeId   String   @map("store_id") @db.Uuid
  name      String   @db.VarChar(255)
  email     String?  @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  address   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  store               Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productProviders    ProductProvider[]
  productTransactions ProductTransaction[]

  @@map("pos_providers")
}

model StoreBranch {
  id        String   @id @default(uuid()) @db.Uuid
  storeId   String   @map("store_id") @db.Uuid
  name      String   @db.VarChar(255)
  location  String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  store      Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  warehouses Warehouse[]
  orders     Order[]

  @@map("pos_store_branches")
}

model Warehouse {
  id        String   @id @default(uuid()) @db.Uuid
  storeId   String   @map("store_id") @db.Uuid
  branchId  String?  @map("branch_id") @db.Uuid
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  store               Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  branch              StoreBranch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  productTransactions ProductTransaction[]

  @@map("pos_warehouses")
}

model Product {
  id           String   @id @default(uuid()) @db.Uuid
  storeId      String   @map("store_id") @db.Uuid
  sku          String?  @db.VarChar(100)
  name         String   @db.VarChar(255)
  costPrice    Decimal  @default(0) @map("cost_price") @db.Decimal(15, 2)
  currentPrice Decimal  @map("current_price") @db.Decimal(15, 2)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  store               Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productProviders    ProductProvider[]
  productTransactions ProductTransaction[]
  orderLines          OrderLine[]

  @@map("pos_products")
}

model ProductProvider {
  id          String   @id @default(uuid()) @db.Uuid
  storeId     String   @map("store_id") @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  providerId  String   @map("provider_id") @db.Uuid
  catalogCost Decimal? @map("catalog_cost") @db.Decimal(15, 2)
  providerSku String?  @map("provider_sku") @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([productId, providerId])
  @@map("pos_product_providers")
}

model ProductTransaction {
  id              String   @id @default(uuid()) @db.Uuid
  storeId         String   @map("store_id") @db.Uuid
  warehouseId     String   @map("warehouse_id") @db.Uuid
  productId       String   @map("product_id") @db.Uuid
  providerId      String?  @map("provider_id") @db.Uuid 
  transactionType String   @map("transaction_type") @db.VarChar(50)
  quantity        Decimal  @db.Decimal(10, 2)
  unitCost        Decimal? @map("unit_cost") @db.Decimal(15, 2)
  referenceId     String?  @map("reference_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])
  provider  Provider? @relation(fields: [providerId], references: [id], onDelete: SetNull)

  @@map("pos_product_transactions")
}

// =========================================================================
// FINANCIAL & CHECKOUT (Unified)
// =========================================================================

model Order {
  id                String   @id @default(uuid()) @db.Uuid
  storeId           String   @map("store_id") @db.Uuid
  branchId          String   @map("branch_id") @db.Uuid
  customerId        String?  @map("customer_id") @db.Uuid
  
  fulfillmentStatus String   @default("PENDING") @map("fulfillment_status") @db.VarChar(50) // PENDING, COMPLETED, CANCELLED
  paymentStatus     String   @default("UNPAID") @map("payment_status") @db.VarChar(50) // UNPAID, PARTIAL, PAID
  
  totalAmount       Decimal  @map("total_amount") @db.Decimal(15, 2)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  store      Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  branch     StoreBranch @relation(fields: [branchId], references: [id])
  customer   Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  orderLines OrderLine[]
  payments   Payment[]   // Linked directly to Order now

  @@map("pos_orders")
}

model OrderLine {
  id              String   @id @default(uuid()) @db.Uuid
  storeId         String   @map("store_id") @db.Uuid
  orderId         String   @map("order_id") @db.Uuid
  productId       String?  @map("product_id") @db.Uuid
  quantity        Decimal  @db.Decimal(10, 2)
  unitCost        Decimal  @default(0) @map("unit_cost") @db.Decimal(15, 2)
  unitPrice       Decimal  @map("unit_price") @db.Decimal(15, 2)
  productSnapshot Json     @map("product_snapshot")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  store   Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("pos_order_lines")
}

model Payment {
  id            String   @id @default(uuid()) @db.Uuid
  storeId       String   @map("store_id") @db.Uuid
  orderId       String   @map("order_id") @db.Uuid // Directly references the Order
  amount        Decimal  @db.Decimal(15, 2)
  paymentMethod String   @map("payment_method") @db.VarChar(50)
  paymentDate   DateTime @default(now()) @map("payment_date") @db.Timestamptz

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("pos_payments")
}